EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_REDIRECT_URL=overthought://auth

# Off by default. Enable after Apple Developer App IDs and Supabase Apple provider setup.
EXPO_PUBLIC_ENABLE_APPLE_AUTH=false

# Off by default. Enable after Google Cloud OAuth and Supabase Google provider setup.
EXPO_PUBLIC_ENABLE_GOOGLE_AUTH=false
# Normal iOS OAuth client ID, ending in .apps.googleusercontent.com.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Web OAuth client ID used by native Google Sign-In as the server client ID.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Reversed iOS client ID, not the normal client ID.
# Example: com.googleusercontent.apps.1234567890-abcdef
# Supabase Auth > Providers > Google also needs Skip nonce check enabled for native iOS Google Sign-In.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

EXPO_PUBLIC_ENABLE_PREMIUM=false
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=
